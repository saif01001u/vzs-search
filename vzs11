    const COINGECKO_BASE = 'https://api.coingecko.com/api/v3';

    // Helper: fetch coin market data by id (supports any valid coin id)
    async function fetchCoinData(coinId) {
        try {
            // Fetch market data + additional info
            const url = `${COINGECKO_BASE}/coins/${encodeURIComponent(coinId)}?tickers=false&market_data=true&community_data=false&developer_data=true&sparkline=false`;
            const response = await fetch(url);
            if (!response.ok) {
                if (response.status === 404) throw new Error('Coin not found. Check name or symbol.');
                throw new Error(`API error: ${response.status}`);
            }
            const data = await response.json();
            return data;
        } catch (error) {
            console.error('CoinGecko fetch error:', error);
            throw error;
        }
    }

    // Search coin by name or symbol to get the correct coin id (CoinGecko search endpoint)
    async function searchCoin(query) {
        try {
            const searchUrl = `${COINGECKO_BASE}/search?query=${encodeURIComponent(query)}`;
            const searchResp = await fetch(searchUrl);
            if (!searchResp.ok) throw new Error('Search failed');
            const searchData = await searchResp.json();
            if (searchData.coins && searchData.coins.length > 0) {
                return searchData.coins[0].id; // return best match id
            }
            return null;
        } catch (err) {
            console.warn('Search error, falling back to raw query', err);
            return null;
        }
    }

